# =============================================================
# Laravel Cloud — Environment Variables
# Copy these into the Laravel Cloud dashboard (Environment tab)
# Values marked [FILL] must be provided; others have safe defaults
# =============================================================

APP_NAME=Vaelthorn
APP_ENV=production
APP_KEY=[FILL — run: php artisan key:generate --show]
APP_DEBUG=false
APP_URL=[FILL — e.g. https://vaelthorn.laravel.cloud]

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=cache

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database (Laravel Cloud managed MySQL) ---
DB_CONNECTION=mysql
DB_HOST=[FILL — from Laravel Cloud DB panel]
DB_PORT=3306
DB_DATABASE=[FILL]
DB_USERNAME=[FILL]
DB_PASSWORD=[FILL]

# --- Session / Cache / Queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE=vaelthorn_session

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- File Storage (Tigris) ---
FILESYSTEM_DISK=tigris
TIGRIS_ACCESS_KEY_ID=[FILL — from Laravel Cloud Storage panel]
TIGRIS_SECRET_ACCESS_KEY=[FILL]
TIGRIS_BUCKET=[FILL]
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev
TIGRIS_REGION=auto
TIGRIS_URL=[FILL — public URL of your Tigris bucket]

# --- Notifications ---
DISCORD_WEBHOOK_URL=[FILL — optional]

# --- Mail (configure if needed) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@vaelthorn.laravel.cloud
MAIL_FROM_NAME=Vaelthorn

VITE_APP_NAME=Vaelthorn
